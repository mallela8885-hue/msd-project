# Application Configuration
NODE_ENV=development
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/msd-project

# Redis Configuration (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Docker Configuration
DOCKER_ENABLED=false
DOCKER_SOCKET=/var/run/docker.sock

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# PaaS Infrastructure
# Worker Node Configuration
NODE_ID=backend-1
REGION=us-east-1
MAX_CONCURRENT_JOBS=2

# Port Range for Container Routing
PORT_RANGE_START=3001
PORT_RANGE_END=4000

# Deployment Strategy
DEPLOYMENT_STRATEGY=internal
# Options: "internal" (default to Docker), "provider" (use external providers), "hybrid" (choose based on availability)

# Worker Node Configuration
NODE_IP=127.0.0.1
BACKEND_URL=http://localhost:3000

# Stripe (if payment features enabled)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Logging
LOG_LEVEL=info

# Cleanup Job Configuration
CLEANUP_INTERVAL_HOURS=24
